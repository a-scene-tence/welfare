# LLM 공급자: anthropic | openai | gemini (1차 릴리스는 anthropic만 구현)
LLM_PROVIDER=anthropic

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5

# OpenAI (stub)
OPENAI_API_KEY=
OPENAI_MODEL=

# Google (stub)
GOOGLE_API_KEY=
GEMINI_MODEL=

# Opt-in 비식별 로깅용 Postgres (선택)
DATABASE_URL=

# IP rate limit (선택, Upstash Redis REST)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# 빌드 타겟: web | appsintoss
NEXT_PUBLIC_TARGET=web
