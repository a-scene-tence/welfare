# LLM 공급자: anthropic | openai | gemini | upstage
LLM_PROVIDER=upstage

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5

# Upstage Solar API (한국어 특화, OpenAI 호환, solar-pro2 무료 티어)
# https://console.upstage.ai → API Keys
UPSTAGE_API_KEY=up-...
UPSTAGE_MODEL=solar-pro2

# Tavily 외부 웹 검색 (Upstage·OpenAI·Gemini용; Anthropic은 네이티브 web_search 사용)
# 무료 1000회/월 — https://app.tavily.com → Sign Up → API Keys
TAVILY_API_KEY=tvly-...

# OpenAI (stub)
OPENAI_API_KEY=
OPENAI_MODEL=

# Google (stub)
GOOGLE_API_KEY=
GEMINI_MODEL=

# Opt-in 비식별 로깅용 Supabase (선택)
# https://supabase.com → New Project → Settings → API
# 미설정 시 stdout 로그만 사용 (서비스는 정상 동작). 자세한 셋업은 db/README.md 참고.
SUPABASE_URL=https://xxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# IP rate limit (선택, Upstash Redis REST)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# 빌드 타겟: web | appsintoss
NEXT_PUBLIC_TARGET=web
