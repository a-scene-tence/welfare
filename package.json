  "private": true,
  "description": "대한민국 공공 복지 매칭 에이전트",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:appsintoss": "NEXT_PUBLIC_TARGET=appsintoss next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
